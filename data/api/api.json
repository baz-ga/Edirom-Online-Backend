{
	"openapi": "3.0.1",
	"info": {
		"title": "Edirom Online API",
		"description": "This is the description and documentation of the Edirom-Online backend API.",
		"licence": {
			"name": "MIT"
		},
		"version": "2.0.0-alpha"
	},
	"servers": [
		{
			"description": "Local backend with EditionExample and Klarinettenquintett",
			"url": "http://localhost:8080/exist/apps/Edirom-Online-Backend"
		}
	],
	"tags": [
		{
			"name": "entry",
			"description": "Entry endpoint"
		},
		{
			"name": "collection",
			"description": "Collection endpoint"
		},
		{
			"name": "navigation",
			"description": "Navigation endpoint"
		},
		{
			"name": "document",
			"description": "Document endpoint"
		}
	],
	"components": {
		"securitySchemes": {
			"basicAuth": {
				"type": "http",
				"scheme": "basic"
			},
			"cookieAuth": {
				"type": "apiKey",
				"name": "example.com.login",
				"in": "cookie"
			}
		}
	},
	"paths": {
		"/api": {
			"get": {
				"summary": "API entry endpoint",
				"description": "This is the entry point for the API.",
				"operationId": "api:entryPoint",
				"tags": ["entry"],
				"responses": {
					"200": {
						"description": "Succesful response",
						"content": {
							"application/ld+json": {
								"schema": {
									"type": "object",
									"properties": {
										"message": {
											"type": "string"
										}
									}
								}
							}
						}
					},
					"404": {
						"description": "Not found"
					},
					"500": {
						"description": "Internal server error"
					}
				}
			}
		},
		"/api/document": {
				"get": {
					"summary": "Document endpoint",
					"description": "This endpoint returns a document or part of a document.",
					"operationId": "api:document",
					"tags": ["document"],
					"parameters": [
						{
							"name": "resource",
							"in": "query",
							"required": true,
							"schema": {
								"type": "string"
							},
							"examples": {
								"Klarinettenquintett": {
									"summary": "Klarinettenquintett",
									"value": "xmldb:exist:///db/apps/weber-klarinettenquintett-eol-emeritus/sources/source-4-MEI.xml"
								}
							}
						},
						{
							"name": "ref",
							"in": "query",
							"required": false,
							"description": "NOT used with start and end",
							"schema": {
								"type": "string"
							},
							"examples": {
								"Empty": {
									"summary": "Empty",
									"value": ""
								},
								"Allegro": {
									"summary": "Allegro",
									"value": "tf280fcd0-c18e-42b4-8ec3-8166ac51f7cf"
								},
								"Fantasia": {
									"summary": "Fantasia",
									"value": "x7a9f679a-a4d3-4d02-8a93-1f697f2f9ea2"
								},
								"Menuetto Capriccio": {
									"summary": "Menuetto Capriccio",
									"value": "x19d7fd5c-b8b4-47d8-8967-c6a27b5cd1a9"
								},
								"Rondo": {
									"summary": "Rondo",
									"value": "xf1c9b711-1ab7-47c5-afea-e0551799da6c"
								}
							}
						},
						{
							"name": "start",
							"in": "query",
							"required": false,
							"description": "NOT used if a ref is specified, requires end as well",
							"schema": {
								"type": "string"
							},
							"examples": {
								"Empty": {
									"summary": "Empty",
									"value": ""
								},
								"Allegro": {
									"summary": "Allegro",
									"value": "tf280fcd0-c18e-42b4-8ec3-8166ac51f7cf"
								},
								"Fantasia": {
									"summary": "Fantasia",
									"value": "x7a9f679a-a4d3-4d02-8a93-1f697f2f9ea2"
								},
								"Menuetto Capriccio": {
									"summary": "Menuetto Capriccio",
									"value": "x19d7fd5c-b8b4-47d8-8967-c6a27b5cd1a9"
								},
								"Rondo": {
									"summary": "Rondo",
									"value": "xf1c9b711-1ab7-47c5-afea-e0551799da6c"
								}
							}
						},
						{
							"name": "end",
							"in": "query",
							"required": false,
							"description": "NOT used if a ref is specified, requires start as well",
							"schema": {
								"type": "string"
							},
							"examples": {
								"Empty": {
									"summary": "Empty",
									"value": ""
								},
								"Allegro": {
									"summary": "Allegro",
									"value": "tf280fcd0-c18e-42b4-8ec3-8166ac51f7cf"
								},
								"Fantasia": {
									"summary": "Fantasia",
									"value": "x7a9f679a-a4d3-4d02-8a93-1f697f2f9ea2"
								},
								"Menuetto Capriccio": {
									"summary": "Menuetto Capriccio",
									"value": "x19d7fd5c-b8b4-47d8-8967-c6a27b5cd1a9"
								},
								"Rondo": {
									"summary": "Rondo",
									"value": "xf1c9b711-1ab7-47c5-afea-e0551799da6c"
								}
							}
						},
						{
							"name": "tree",
							"in": "query",
							"required": false,
							"schema": {
								"type": "string",
								"enum": [
									"movement",
									"page"
								],
								"default": "movement"
							},
							"examples": {
								"movement": {
									"summary": "movement",
									"value": "movement"
								},
								"page": {
									"summary": "page",
									"value": "page"
								}
							}
						},
						{
							"name": "mediaType",
							"in": "query",
							"required": false,
							"schema": {
								"type": "string",
								"enum": [
									"text/html",
									"application/mei+xml",
									"application/tei+xml"
								],
								"default": "application/mei+xml"
							},
							"examples": {
								"xml": {
									"summary": "xml",
									"value": "xml"
								},
								"html": {
									"summary": "html",
									"value": "html"
								}
							}
						}
				],
				"responses": {
					"200": {
						"description": "Succesful response"
					},
					"400": {
						"description": "Bad request"
					},
					"500": {
						"description": "Internal server error"
					}
				}
			}
		}
	},
	"security": [
		{
			"cookieAuth": []
		},
		{
			"basicAuth": []
		}
	]
}
